# =============================================================================
# BUILDEX — server-side configuration
# Copy to /root/buildex/.env and fill in real values.
# =============================================================================

# Local SQLite database (defaults to <project>/var/buildex.db if unset)
# DB_PATH=/root/buildex/var/buildex.db

# Admin dashboard password (required to log into /admin/leads)
ADMIN_PASSWORD=change-me-now

# --- SMTP for email notifications -------------------------------------------
# Sends a clean email to NOTIFY_EMAIL on every form interaction (lead capture,
# booking, etc.). If unset, the site still works but no notifications go out.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=mrefaie@milaknights.com
SMTP_PASS=
SMTP_FROM="BUILDEX <mrefaie@milaknights.com>"
NOTIFY_EMAIL=mrefaie@milaknights.com

# --- Public client config (visible in browser) ------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=963000000000
# Optional analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
